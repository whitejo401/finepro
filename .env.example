# ============================================================
# Financial Data Project - API Keys Template
# 이 파일을 .env로 복사하고 실제 키를 입력하세요
# .env 파일은 절대 git에 커밋하지 마세요
# ============================================================

# 국내 주식/재무
DART_API_KEY=           # https://opendart.fss.or.kr
KIS_APP_KEY=            # https://apiportal.koreainvestment.com
KIS_APP_SECRET=

# 국내 공공 데이터
ECOS_API_KEY=           # https://ecos.bok.or.kr (한국은행)
DATA_GO_KR_API_KEY=     # https://data.go.kr (공공데이터포털)
MOLIT_API_KEY=          # 국토교통부 실거래가 (data.go.kr에서 발급)

# 미국/글로벌 거시
FRED_API_KEY=           # https://fred.stlouisfed.org/docs/api/api_key.html
EIA_API_KEY=            # https://www.eia.gov/opendata/register.php

# 암호화폐
COINGECKO_API_KEY=      # https://www.coingecko.com/en/api (Pro, 무료는 불필요)
GLASSNODE_API_KEY=      # https://glassnode.com

# 뉴스/소셜
NEWS_API_KEY=           # https://newsapi.org
REDDIT_CLIENT_ID=       # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=financial-data-bot/1.0
